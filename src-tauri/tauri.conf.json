{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tracker",
  "version": "0.1.0",
  "identifier": "dev.local.tracker",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tracker",
        "width": 1040,
        "height": 760,
        "minWidth": 820,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

